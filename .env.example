# ============================================
#   CIELORA BACKEND — Environment Variables
#   Copy this file to .env and fill in values
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
# Go to: mongodb.com/atlas → Create cluster → Connect → Drivers → Copy URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cielora?retryWrites=true&w=majority

# JWT Secret (any long random string)
JWT_SECRET=cielora_super_secret_jwt_key_change_this_in_production_2025
JWT_EXPIRE=7d

# Admin default credentials (change after first login!)
ADMIN_EMAIL=admin@cielora.in
ADMIN_PASSWORD=Cielora@Admin123

# Razorpay (Indian payment gateway — free account at razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Nodemailer (Gmail SMTP)
# Gmail: Enable 2FA → App Passwords → Create app password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=Cielora <hello@cielora.in>

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload (local storage, can upgrade to S3 later)
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
